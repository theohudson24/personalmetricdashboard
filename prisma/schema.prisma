generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model UserSettings {
  id                  String   @id @default(cuid())
  profileId           String   @unique
  dailyCalorieGoal    Int      @default(3000)
  dailyProteinGoal    Int      @default(180)
  dailyCarbGoal       Int      @default(350)
  dailyFatGoal        Int      @default(85)
  dailyFiberGoal      Int      @default(30)
  dailyWaterGoal      Int      @default(128)
  dailyVitaminAGoal   Float    @default(900)
  dailyVitaminCGoal   Float    @default(90)
  dailyVitaminDGoal   Float    @default(15)
  dailyVitaminB12Goal Float    @default(2.4)
  dailyCalciumGoal    Float    @default(1000)
  dailyIronGoal       Float    @default(8)
  dailyMagnesiumGoal  Float    @default(400)
  dailyPotassiumGoal  Float    @default(3400)
  dailyZincGoal       Float    @default(11)
  dailySodiumLimit    Float    @default(2300)
  useRecommendedGoals Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Profile {
  id                     String                         @id @default(cuid())
  authUserId             String                         @unique
  displayName            String
  isDefault              Boolean                        @default(false)
  heightInches           Float?
  weightLb               Float?
  age                    Int?
  gender                 String?
  activityLevel          String?                        @default("moderate")
  phone                  String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  settings               UserSettings?
  workouts               Workout[]
  workoutTemplates       WorkoutTemplate[]
  dailyLogs              DailyLog[]
  todoItems              TodoItem[]
  bodyMeasurements       BodyMeasurement[]
  meals                  Meal[]
  mealTemplates          MealTemplate[]
  savedFoods             SavedFood[]
  bugReports             BugReport[]
  errorEvents            ErrorEvent[]
  deletionRequests       AccountDeletionRequest[]
  habits                 Habit[]
  selfImprovementGoals   SelfImprovementGoal[]
  selfImprovementMetrics SelfImprovementMetric[]
  selfImprovementChecks  SelfImprovementCheckIn[]
  selfImprovementPhotos  SelfImprovementPhoto[]
  improvementRoutines    SelfImprovementRoutine[]
  improvementChecklist   SelfImprovementChecklistItem[]
  improvementReviews     SelfImprovementWeeklyReview[]
}

model Habit {
  id           String            @id @default(cuid())
  profileId    String
  name         String
  type         String
  category     String
  difficulty   String
  frequency    String
  targetAmount String            @default("")
  reminderTime String            @default("")
  reason       String            @default("")
  notes        String            @default("")
  status       String            @default("Active")
  bestStreak   Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  profile      Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  completions  HabitCompletion[]
  relapses     HabitRelapse[]

  @@index([profileId])
  @@index([profileId, status])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  status    String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

model HabitRelapse {
  id             String   @id @default(cuid())
  habitId        String
  date           DateTime
  trigger        String   @default("")
  emotion        String   @default("")
  location       String   @default("")
  timeOfDay      String   @default("")
  reflection     String   @default("")
  preventionPlan String   @default("")
  createdAt      DateTime @default(now())
  habit          Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId, date])
}

model SelfImprovementGoal {
  id           String    @id @default(cuid())
  profileId    String
  title        String
  category     String
  currentValue Float     @default(0)
  targetValue  Float     @default(100)
  deadline     DateTime?
  priority     String    @default("Medium")
  progress     Int       @default(0)
  linkedHabits String    @default("")
  status       String    @default("Not Started")
  notes        String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
}

model SelfImprovementMetric {
  id        String   @id @default(cuid())
  profileId String
  category  String
  name      String
  value     Float
  unit      String
  target    Float?
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, name])
  @@index([profileId, category])
}

model SelfImprovementCheckIn {
  id                   String   @id @default(cuid())
  profileId            String
  date                 DateTime
  sleepHours           Float
  sleepQuality         Int
  energy               Int
  mood                 Int
  stress               Int
  workoutCompleted     Boolean
  steps                Int
  nutritionQuality     Int
  protein              Float
  water                Float
  skincareCompleted    Boolean
  supplementsCompleted Boolean
  deepWorkMinutes      Int
  screenTimeRating     Int
  confidence           Int
  notes                String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
}

model SelfImprovementPhoto {
  id        String   @id @default(cuid())
  profileId String
  angle     String
  date      DateTime
  notes     String   @default("")
  fileName  String   @default("")
  objectKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, date])
}

model SelfImprovementRoutine {
  id               String                       @id @default(cuid())
  profileId        String
  name             String
  category         String
  frequency        String
  preferredTime    String?
  estimatedMinutes Int                          @default(10)
  notes            String?
  archived         Boolean                      @default(false)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  profile          Profile                      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tasks            SelfImprovementRoutineTask[]

  @@index([profileId, archived])
}

model SelfImprovementRoutineTask {
  id         String                 @id @default(cuid())
  routineId  String
  title      String
  orderIndex Int
  completed  Boolean                @default(false)
  routine    SelfImprovementRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId, orderIndex])
}

model SelfImprovementChecklistItem {
  id        String   @id @default(cuid())
  profileId String
  date      DateTime
  title     String
  category  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date, title])
  @@index([profileId, date])
}

model SelfImprovementWeeklyReview {
  id                 String   @id @default(cuid())
  profileId          String
  weekStart          DateTime
  wentWell           String
  difficult          String
  improvedCategory   String
  attentionCategory  String
  confidence         Int
  positiveDifference String
  adjustment         String
  priorities         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  profile            Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, weekStart])
  @@index([profileId])
}

model DailyLog {
  id               String   @id @default(cuid())
  profileId        String
  date             DateTime
  bodyWeight       Float?
  sleepHours       Float?
  restingHeartRate Int?
  mood             Int?
  energyLevel      Int?
  sorenessLevel    Int?
  stressLevel      Int?
  waterIntake      Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
}

model TodoItem {
  id        String   @id @default(cuid())
  profileId String
  date      DateTime
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date, title])
  @@index([date])
  @@index([profileId])
}

model Workout {
  id              String     @id @default(cuid())
  profileId       String
  date            DateTime
  name            String
  duration        String?
  durationMinutes Int?
  muscleGroups    String
  notes           String?
  source          String     @default("manual")
  externalId      String?
  exercises       Exercise[]
  profile         Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([profileId, source, externalId])
  @@index([date])
  @@index([profileId])
  @@index([source])
}

model Exercise {
  id          String        @id @default(cuid())
  workoutId   String
  name        String
  muscleGroup String
  notes       String?
  workout     Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets        ExerciseSet[]

  @@index([workoutId])
  @@index([name])
}

model ExerciseSet {
  id         String   @id @default(cuid())
  exerciseId String
  setNumber  Int
  setType    String   @default("WORKING")
  reps       Int
  weight     Float
  distance   Float    @default(0)
  seconds    Float    @default(0)
  rpe        Float?
  notes      String?
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model WorkoutTemplate {
  id        String                    @id @default(cuid())
  profileId String
  name      String
  notes     String?
  exercises WorkoutTemplateExercise[]
  profile   Profile                   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@unique([profileId, name])
  @@index([profileId])
}

model WorkoutTemplateExercise {
  id          String               @id @default(cuid())
  templateId  String
  orderIndex  Int
  name        String
  muscleGroup String
  notes       String?
  template    WorkoutTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sets        WorkoutTemplateSet[]

  @@index([templateId])
}

model WorkoutTemplateSet {
  id         String                  @id @default(cuid())
  exerciseId String
  setNumber  Int
  setType    String                  @default("WORKING")
  reps       Int
  weight     Float
  exercise   WorkoutTemplateExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model BodyMeasurement {
  id         String   @id @default(cuid())
  profileId  String
  date       DateTime
  bodyWeight Float?
  chest      Float?
  arms       Float?
  waist      Float?
  legs       Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([profileId])
}

model Meal {
  id        String     @id @default(cuid())
  profileId String
  date      DateTime
  mealType  MealType
  mealName  String
  entryKind String     @default("MEAL")
  time      String?
  notes     String?
  foodItems FoodItem[]
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([date])
  @@index([profileId])
}

model FoodItem {
  id          String   @id @default(cuid())
  mealId      String
  name        String
  servingSize String?
  calories    Int      @default(0)
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  fiber       Float    @default(0)
  sugar       Float    @default(0)
  sodium      Float    @default(0)
  vitaminA    Float    @default(0)
  vitaminC    Float    @default(0)
  vitaminD    Float    @default(0)
  vitaminB12  Float    @default(0)
  calcium     Float    @default(0)
  iron        Float    @default(0)
  magnesium   Float    @default(0)
  potassium   Float    @default(0)
  zinc        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
}

model SavedFood {
  id           String   @id @default(cuid())
  profileId    String
  barcode      String
  name         String
  brand        String?
  source       String   @default("User corrected")
  servingGrams Float    @default(100)
  servingLabel String?
  calories     Float    @default(0)
  protein      Float    @default(0)
  carbs        Float    @default(0)
  fat          Float    @default(0)
  fiber        Float    @default(0)
  sugar        Float    @default(0)
  sodium       Float    @default(0)
  vitaminA     Float    @default(0)
  vitaminC     Float    @default(0)
  vitaminD     Float    @default(0)
  vitaminB12   Float    @default(0)
  calcium      Float    @default(0)
  iron         Float    @default(0)
  magnesium    Float    @default(0)
  potassium    Float    @default(0)
  zinc         Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, barcode])
  @@index([profileId, updatedAt])
}

model BugReport {
  id             String   @id @default(cuid())
  profileId      String
  category       String
  summary        String
  description    String
  pageUrl        String?
  deviceInfo     String?
  status         String   @default("OPEN")
  developerNotes String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([status, createdAt])
}

model ErrorEvent {
  id          String   @id @default(cuid())
  profileId   String
  fingerprint String
  route       String
  category    String
  digest      String?
  deviceClass String?
  occurrences Int      @default(1)
  status      String   @default("OPEN")
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, fingerprint])
  @@index([lastSeenAt])
}

model AccountDeletionRequest {
  id          String    @id @default(cuid())
  profileId   String?
  authUserId  String
  displayName String
  reason      String?
  status      String    @default("REQUESTED")
  adminNotes  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviewedAt  DateTime?
  profile     Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt])
  @@index([status, createdAt])
}

model MealTemplate {
  id        String             @id @default(cuid())
  profileId String
  name      String
  mealType  MealType
  notes     String?
  foodItems MealTemplateItem[]
  profile   Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([profileId, name])
  @@index([profileId])
}

model MealTemplateItem {
  id          String       @id @default(cuid())
  templateId  String
  name        String
  servingSize String?
  calories    Int          @default(0)
  protein     Float        @default(0)
  carbs       Float        @default(0)
  fat         Float        @default(0)
  fiber       Float        @default(0)
  sugar       Float        @default(0)
  sodium      Float        @default(0)
  vitaminA    Float        @default(0)
  vitaminC    Float        @default(0)
  vitaminD    Float        @default(0)
  vitaminB12  Float        @default(0)
  calcium     Float        @default(0)
  iron        Float        @default(0)
  magnesium   Float        @default(0)
  potassium   Float        @default(0)
  zinc        Float        @default(0)
  template    MealTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

model ExerciseCatalog {
  id           String   @id @default(cuid())
  name         String   @unique
  muscleGroup  String
  category     String   @default("Strength")
  equipment    String?
  aliases      String?
  importedFrom String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([muscleGroup])
  @@index([category])
}
